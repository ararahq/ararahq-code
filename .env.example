# Jade Code — environment. BRING YOUR OWN KEY.
# Per-project: copy this to .env in your project dir (Bun auto-loads it).
# Global (set once, any project): put the same line in ~/.arara/.env
# A shell `export` also works and takes precedence over both.
# (.env is gitignored; never commit real keys.)

# REQUIRED — your OpenRouter API key. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OPTIONAL — local Ollama for trivial/chat turns (free). Default shown.
OLLAMA_URL=http://localhost:11434

# OPTIONAL — extra skill directories (colon-separated), e.g. skills from another agent.
# ARARA_SKILLS_DIRS=/path/to/skills:/another/path

# OPTIONAL — verbose internal logging.
# ARARA_DEBUG=1

# ══ Autonomous mode (Devin-mode: gateway + fila + sandbox) — all OPTIONAL for the CLI ══
# Gateway (webhook receiver): bun run gateway
# JADE_GATEWAY_PORTA=8787
# JADE_FILA_DB=jade-fila.sqlite
# JADE_CALLBACK_URL=            # public URL of POST /interno/resultado (sandbox reports here)
# JADE_CALLBACK_SECRET=         # HMAC secret for the sandbox->gateway callback
#
# Git delivery (PRs). Use a token scoped to the target repos only.
# JADE_GIT_TOKEN=
# JADE_REPO_PADRAO=             # "owner/repo" used when the message doesn't name one
# JADE_BRANCH_BASE=main
#
# Sandbox driver: bun run despachante
# JADE_SANDBOX_DRIVER=docker    # docker (local dev) | fly (prod)
# JADE_SANDBOX_IMAGEM=jade-sandbox
# JADE_MAX_SANDBOXES=3
# FLY_API_TOKEN=                # fly driver only
# JADE_FLY_APP=                 # fly driver only
#
# Triggers — configure only the ones you use. Signatures are verified BEFORE anything persists.
# WhatsApp (Meta Cloud API):
# JADE_WHATSAPP_APP_SECRET=     # webhook signature (X-Hub-Signature-256)
# JADE_WHATSAPP_VERIFY_TOKEN=   # GET handshake
# JADE_WHATSAPP_TOKEN=          # send messages
# JADE_WHATSAPP_PHONE_ID=
# Slack (slash command /jade):
# JADE_SLACK_SIGNING_SECRET=
# JADE_SLACK_BOT_TOKEN=         # chat.postMessage (reply survives long tasks)
# Discord (slash command /jade):
# JADE_DISCORD_PUBLIC_KEY=      # Ed25519 interaction signature
# JADE_DISCORD_BOT_TOKEN=       # channel message reply
# Linear (webhook on Comment, mention @jade):
# JADE_LINEAR_WEBHOOK_SECRET=
# JADE_LINEAR_TOKEN=            # comment back on the issue
# Jira Cloud (webhook comment_created, mention @jade; auth = shared secret in the URL):
# JADE_JIRA_WEBHOOK_SECRET=
# JADE_JIRA_BASE_URL=           # https://yourorg.atlassian.net
# JADE_JIRA_EMAIL=
# JADE_JIRA_TOKEN=

# ── Advanced tuning (sane defaults live in code; override only if you know why) ──
# MAX_PASSOS=6             # navigation step ceiling
# NAV_BUDGET_MS=70000      # soft time budget for the navigation loop
# NAV_DEADLINE_MS=110000   # hard deadline — abstains honestly instead of hanging
# COM_VERIFICADOR=0        # 1 = enable the strong-model cause verifier (off by default)
# VERIF_FORTE=0            # 1 = use the strongest model for verification
# VERIF_BUDGET_MS=25000    # verifier internal timeout
